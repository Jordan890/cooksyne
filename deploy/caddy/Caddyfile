# ─────────────────────────────────────────────────────────────────────
# Caddyfile – Cart & Cook reverse proxy with Tailscale TLS
#
# When TS_HOSTNAME is set, Caddy obtains TLS certificates from
# Tailscale automatically (no manual OpenSSL cert generation needed).
#
# Usage without Tailscale: replace the {$TS_HOSTNAME} blocks with
# your domain name and a standard tls directive.
# ─────────────────────────────────────────────────────────────────────

# Tailscale transport module (loaded via caddy-tailscale plugin)
{
    tailscale
}

# Redirect all HTTP to HTTPS
http:// {
    redir https://{host}{uri} permanent
}

# Main HTTPS site — Tailscale manages TLS automatically
{$TS_HOSTNAME:localhost} {
    encode gzip

    # Tailscale TLS — no manual cert paths needed
    tls {
        get_certificate tailscale
    }

    route {

        # Keycloak — proxy to HTTPS (Keycloak has its own TLS cert)
        handle /auth* {
            reverse_proxy https://keycloak:8443 {
                transport http {
                    tls_insecure_skip_verify
                }
                header_up Host {http.request.host}
                header_up X-Forwarded-Proto {http.request.scheme}
                header_up Forwarded proto={http.request.scheme};host={http.request.host}
                header_up X-Forwarded-For {http.request.remote}
                header_up X-Forwarded-Host {http.request.host}
            }
        }

        # Backend API
        handle_path /cart-and-cook/api/* {
            uri strip_prefix /cart-and-cook/api
            reverse_proxy backend:8081
        }

        # Angular SPA
        handle_path /cook-and-cook* {
            reverse_proxy frontend:80
        }

        # SPA fallback
        handle {
            reverse_proxy frontend:80
        }
    }
}