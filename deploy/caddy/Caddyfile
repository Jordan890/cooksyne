# ─────────────────────────────────────────────────────────────────────
# Cart & Cook — Caddy reverse proxy with Tailscale HTTPS
# ─────────────────────────────────────────────────────────────────────
# Caddy obtains TLS certificates automatically from Tailscale.
# All browser traffic arrives over HTTPS on the tailnet hostname.
# Internal traffic (Caddy → services) is plain HTTP over the Docker network.
# ─────────────────────────────────────────────────────────────────────

{
	tailscale {
		auth_key {env.TS_AUTHKEY}
	}
}

# Bind to the Tailscale network listener and serve with auto TLS
:443 {
	bind tailscale/{env.TS_HOSTNAME}
	tls {
		get_certificate tailscale
	}

	# ── Keycloak (/auth) ────────────────────────────────────────────
	# Keycloak runs at root (/) internally. handle_path strips the
	# /auth prefix before forwarding, so /auth/realms/... becomes
	# /realms/... which Keycloak understands.
	handle_path /auth* {
		reverse_proxy keycloak:8080
	}

	# ── Backend API (/api/*) ─────────────────────────────────────────
	handle /api/* {
		reverse_proxy backend:8081
	}

	# ── Frontend UI (catch-all) ─────────────────────────────────────
	handle {
		reverse_proxy ui:80
	}
}
