# ─────────────────────────────────────────────────────────────────────
# Cart & Cook — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Or run setup.sh to generate secrets automatically:
#   ./setup.sh
# ─────────────────────────────────────────────────────────────────────

# ── Tailscale ─────────────────────────────────────────────────────────
# Machine name on your tailnet (e.g. "cart-and-cook").
# This is used ONLY by Caddy for the Tailscale network binding.
TS_HOSTNAME=cart-and-cook

# Auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable key for persistence across container restarts.
TS_AUTHKEY=

# ── Domain ────────────────────────────────────────────────────────────
# Full domain name where the app is accessible in the browser.
# For Tailscale: <TS_HOSTNAME>.<tailnet-name>.ts.net
# Example: cart-and-cook.your-tailnet.ts.net
# Find your tailnet name at https://login.tailscale.com/admin/machines
DOMAIN=

# ── Image version ────────────────────────────────────────────────────
# Docker image tag for backend and UI.
# Options: "release" (latest stable), or a specific version like "1.0.0"
CART_AND_COOK_VERSION=release

# ── Database ──────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=

# ── Keycloak ──────────────────────────────────────────────────────────
# Admin credentials — used only on first launch to create the admin account.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────
# Base64-encoded X.509 certificate from Keycloak.
# How to get it: Keycloak Admin > Realm Settings > Keys > RS256 row > Certificate
# Leave blank on first launch — see README.md for the two-phase setup.
JWT_PUBLIC_KEY=PLACEHOLDER_FOR_BUILD

# ── UI ────────────────────────────────────────────────────────────────
# Keycloak OIDC client ID (must match the client you create in Keycloak)
AUTH_CLIENT_ID=cart-and-cook-ui

# ── AI providers (optional) ──────────────────────────────────────────
# Uncomment and fill in whichever provider(s) you use.
# Configure the active provider in the UI under Settings > Runtime.

# OPENAI_API_KEY=sk-...
# HUGGINGFACE_API_KEY=hf_...
# OLLAMA_BASE_URL=http://ollama:11434  (default — uses the bundled Ollama container)

# ── Ollama tuning (CPU-optimized defaults) ────────────────────────────
# Model is configured in the app's Runtime Settings page (Settings > Runtime).
# Recommended for CPU-only (4 cores, 8-16GB RAM):
#   qwen2.5:1.5b   — fast, good structured output (recommended)
#   phi3:mini       — 3.8B, slower but more capable
#   tinyllama       — 1.1B, fastest, lower accuracy
# Context window size (tokens). Lower = less RAM, faster inference.
OLLAMA_NUM_CTX=2048
# CPU threads for inference. Set to physical core count (not hyperthreads). 0 = auto.
OLLAMA_NUM_THREAD=4
# Max tokens to generate. Caps output length to prevent runaway generation. 0 = unlimited.
OLLAMA_NUM_PREDICT=512
