# ─────────────────────────────────────────────────────────────────────
# Cart & Cook – Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# ── Version ──────────────────────────────────────────────────────────
# Pin to a specific release or use "release" for the latest stable build.
# Check https://github.com/Jordan890/cart_and_cook/releases for versions.
CART_AND_COOK_VERSION=release

# ── External Services ────────────────────────────────────────────────
# Set to "true" to skip starting the Docker-managed service and use
# your own existing instance instead. Then set the connection details below.
USE_EXTERNAL_DB=false
USE_EXTERNAL_KEYCLOAK=false
USE_PROXY=true

# ── Reverse Proxy (optional)
# Set to true to enable the bundled Caddy reverse proxy (see README).
# When enabled, the proxy maps:
#   /auth              -> Keycloak
#   /cook-and-cart     -> Frontend UI
#   /cart-and-cook/api -> Backend API
PROXY_PORT=8085

# ── Tailscale / Caddy TLS ────────────────────────────────────────────
# Provide a Tailscale auth key so Caddy can register with your tailnet
# and obtain TLS certificates automatically. Generate one at:
#   https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-...
# TS_HOSTNAME=cart-and-cook

# ── Database ─────────────────────────────────────────────────────────
DB_NAME=cart_and_cook
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME
DB_PORT=5432
# Override DB_URL when using an external database (USE_EXTERNAL_DB=true).
# For the Docker-managed Postgres this is set automatically.
# DB_URL=jdbc:postgresql://your-host:5432/cart_and_cook

# ── Keycloak ─────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_PORT=8080
KEYCLOAK_HTTPS_PORT=8443

# Keycloak
KC_HOSTNAME=localhost
KC_HOSTNAME_STRICT=false
KC_PROXY=edge
KEYCLOAK_HTTP_RELATIVE_PATH=/auth
KEYCLOAK_FRONTEND_URL=http://localhost:8080/auth

# ── Backend ──────────────────────────────────────────────────────────
BACKEND_PORT=8081
# Backend
OAUTH2_ISSUER_URI=https://keycloak:8443/auth/realms/cart_and_cook
CORS_ALLOWED_ORIGINS=http://localhost:8080
# ── Frontend ─────────────────────────────────────────────────────────
FRONTEND_PORT=3000
# API URL as seen by the browser (external — use your host address)
# Frontend
API_URL=http://localhost:8081/cart-and-cook/api
AUTH_AUTHORITY=http://localhost:8080/auth/realms/cart_and_cook
AUTH_CLIENT_ID=cart-and-cook-ui

# ── AI Provider ──────────────────────────────────────────────────────
# Options: ollama | openai | bedrock | huggingface
AI_PROVIDER=ollama

AUTH_RUNTIME=oidc

# ── Ollama (default — runs on host, accessed via host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llava-phi3

# ── OpenAI (uncomment and set AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── AWS Bedrock (uncomment and set AI_PROVIDER=bedrock)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ── Hugging Face (uncomment and set AI_PROVIDER=huggingface)
# HUGGINGFACE_API_KEY=hf_...
# HUGGINGFACE_MODEL=Salesforce/blip-image-captioning-large
