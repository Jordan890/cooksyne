# ─────────────────────────────────────────────────────────────────────
# Cooksyne — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Or run setup.sh to generate secrets automatically:
#   ./setup.sh
# ─────────────────────────────────────────────────────────────────────

# ── Compose Profiles ──────────────────────────────────────────────────
# Controls which optional services start. Comma-separated list.
# Available profiles: keycloak, caddy, ollama
# Examples:
#   keycloak,caddy,ollama   — full stack (default)
#   keycloak,ollama         — no Caddy (bring your own reverse proxy)
#   caddy,ollama            — no Keycloak (bring your own auth server)
#   ollama                  — only Ollama (own proxy + own auth)
#   (empty)                 — core only: postgres, backend, UI
COMPOSE_PROFILES=keycloak,caddy,ollama

# ── Domain ────────────────────────────────────────────────────────────
# Full domain name where the app is accessible in the browser.
# For Tailscale: <TS_HOSTNAME>.<tailnet-name>.ts.net
# Example: cooksyne.your-tailnet.ts.net
# For your own proxy: your domain name (e.g. cook.example.com)
DOMAIN=

# ── Application URLs ────────────────────────────────────────────────
# These are derived from DOMAIN by setup.sh. Override for custom setups.
# API_URL: Where the browser reaches the backend API.
API_URL=
# CORS_ALLOWED_ORIGINS: Comma-separated origins the backend accepts.
CORS_ALLOWED_ORIGINS=
# OAUTH2_ISSUER_URI: JWT issuer — must match the "iss" claim in tokens.
# For Keycloak: https://<DOMAIN>/auth/realms/cooksyne
# For Auth0:    https://<tenant>.auth0.com/
# For Okta:     https://<org>.okta.com/oauth2/default
OAUTH2_ISSUER_URI=
# AUTH_AUTHORITY: OIDC discovery base URL for the UI login flow.
# Usually the same as OAUTH2_ISSUER_URI.
AUTH_AUTHORITY=

# ── Image version ────────────────────────────────────────────────────
# Docker image tag for backend and UI.
# Options: "release" (latest stable), or a specific version like "1.0.0"
COOKSYNE_VERSION=release

# ── Database ──────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────
# Base64-encoded X.509 certificate from your OIDC provider.
# For Keycloak: Admin > Realm Settings > Keys > RS256 row > Certificate
# For other providers: export the RS256 signing certificate (base64 X.509, no PEM headers).
# Leave blank on first launch — see README.md for the two-phase setup.
JWT_PUBLIC_KEY=


# ── UI ────────────────────────────────────────────────────────────────
# OIDC client ID (must match the client in your auth provider)
AUTH_CLIENT_ID=cooksyne-ui

# ── Keycloak (only when using the keycloak profile) ───────────────────
# Admin credentials — used only on first launch to create the admin account.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=

# ── Tailscale / Caddy (only when using the caddy profile) ────────────
# Machine name on your tailnet (e.g. "cooksyne").
TS_HOSTNAME=cooksyne
# Auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable key for persistence across container restarts.
TS_AUTHKEY=

# ── AI Provider ──────────────────────────────────────────────────────
# Which AI backend to enable at startup.
# Options: ollama, openai, huggingface, bedrock, disabled
# The active provider and model can also be changed at runtime via
# the app's Settings > Runtime page.
AI_PROVIDER=ollama

# ── AI API Keys (set for whichever provider you use) ─────────────────
# OPENAI_API_KEY=sk-...
# HUGGINGFACE_API_KEY=hf_...

# ── AWS Bedrock (uses default AWS credentials — no key needed here) ───
# Configure AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION
# or use an IAM instance role. Default region: us-east-1.
# Default model: anthropic.claude-3-haiku-20240307-v1:0

# ── Ollama ────────────────────────────────────────────────────────────
# Base URL for Ollama API. Default uses the bundled Ollama container.
# To use an external Ollama instance: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# Ollama tuning (CPU-optimized defaults)
# Model is selected in the app's Settings > Runtime page.
# Recommended for CPU-only (4 cores, 8-16GB RAM):
#   qwen2.5:1.5b   — fast, good structured output (recommended)
#   phi3:mini       — 3.8B, slower but more capable
#   tinyllama       — 1.1B, fastest, lower accuracy
# Context window size (tokens). Lower = less RAM, faster inference.
OLLAMA_NUM_CTX=2048
# CPU threads for inference. Set to physical core count (not hyperthreads). 0 = auto.
OLLAMA_NUM_THREAD=4
# Max tokens to generate. Caps output length to prevent runaway generation. 0 = unlimited.
OLLAMA_NUM_PREDICT=512
